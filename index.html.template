<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ site.description }}" />
  <title>{{ site.title }}</title>
  <link rel="alternate" hreflang="ja" href="{{ hreflang.ja }}" />
  <link rel="alternate" hreflang="en" href="{{ hreflang.en }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ asset_prefix }}css/style.css?v=5" />
</head>
<body>
  <!-- ===== Header / Nav ===== -->
  <header class="site-header" id="top">
    <div class="container nav-bar">
      <a href="#top" class="brand">
        <span class="brand-mark">🎾</span>
        <span class="brand-text">{{ site.brand }}</span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="{{ ui.menu_open }}" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <nav class="nav-menu" id="navMenu">
        <a href="#about">{{ nav.about }}</a>
        <a href="#access">{{ nav.access }}</a>
        <a href="#schedule">{{ nav.schedule }}</a>
        <a href="#fee">{{ nav.fee }}</a>
        <a href="#gallery">{{ nav.gallery }}</a>
        <a href="{{ lang_switch.href }}" class="nav-lang" hreflang="{{ lang_switch.lang }}" lang="{{ lang_switch.lang }}">{{ ui.lang_switch }}</a>
        <a href="#register" class="nav-cta">{{ nav.register }}</a>
      </nav>
    </div>
  </header>

  <!-- ===== Hero ===== -->
  <section class="hero{% if hero.background %} hero--image{% endif %}">
    {%- if hero.background %}
    <div class="hero-media" aria-hidden="true">
      <img class="hero-bg" src="{{ asset_prefix }}{{ hero.background }}" alt="" />
    </div>
    {%- endif %}
    <div class="container hero-content">
      <p class="hero-kicker">{{ hero.kicker }}</p>
      <h1 class="hero-title">{{ hero.title }}</h1>
      <p class="hero-sub">{{ hero.subtitle }}</p>
      <div class="hero-meta">
        {%- for chip in hero.chips %}
        <span class="hero-chip">{{ chip }}</span>
        {%- endfor %}
      </div>
      <div class="hero-actions">
        <a href="#register" class="btn btn-primary">{{ ui.hero_register }}</a>
        <a href="#about" class="btn btn-ghost">{{ ui.hero_learn }}</a>
      </div>
    </div>
  </section>

  <main>
    <!-- ===== About ===== -->
    <section id="about" class="section">
      <div class="container">
        <div class="section-head">
          <span class="section-label">About</span>
          <h2 class="section-title">{{ ui.section_about }}</h2>
        </div>
        <div class="about-grid">
          <div class="about-lead">
            {%- for paragraph in about.paragraphs %}
            <p>{{ paragraph }}</p>
            {%- endfor %}
          </div>
          <ul class="about-points">
            {%- for point in about.points %}
            <li><span class="point-ico">{{ point.icon }}</span><div><strong>{{ point.title }}</strong><p>{{ point.text }}</p></div></li>
            {%- endfor %}
          </ul>
        </div>
        <p class="organizer">{{ ui.organizer_prefix }} {{ about.organizer_main }} ／ {{ ui.organizer_co_prefix }} {{ about.organizer_co }}</p>
      </div>
    </section>

    <!-- ===== Date & Venue ===== -->
    <section id="access" class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Date &amp; Venue</span>
          <h2 class="section-title">{{ ui.section_access }}</h2>
        </div>
        <div class="info-cards">
          <div class="info-card">
            <h3>📅 {{ ui.access_date }}</h3>
            <p class="info-big">{{ access.date.headline }}</p>
            <p>{{ access.date.detail }}</p>
          </div>
          <div class="info-card">
            <h3>📍 {{ ui.access_venue }}</h3>
            <p class="info-big">{{ access.venue.headline }}</p>
            <p>{{ access.venue.detail }}</p>
          </div>
          <div class="info-card">
            <h3>🚃 {{ ui.access_transport }}</h3>
            <p class="info-big">{{ access.transport.headline }}</p>
            <p>{{ access.transport.detail }}</p>
          </div>
        </div>
        {%- if access.map is defined and not access.map.get('hidden') %}
        <div class="map-frame">
          <div class="map-placeholder">
            <span>{{ access.map.message }}</span>
            <a href="{{ access.map.url }}" class="btn btn-ghost btn-sm"{% if access.map.placeholder %} data-placeholder{% endif %}>{{ access.map.label }}</a>
          </div>
        </div>
        {%- elif access.map is defined and access.map.get('hidden') %}
        <p class="map-note">{{ access.map.message }}</p>
        {%- endif %}
      </div>
    </section>

    <!-- ===== Schedule ===== -->
    <section id="schedule" class="section">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Schedule</span>
          <h2 class="section-title">{{ ui.section_schedule }}</h2>
        </div>
        <ol class="timeline">
          {%- for item in schedule.timeline %}
          <li>
            <span class="tl-time">{{ item.time }}</span>
            <div class="tl-body"><strong>{{ item.title }}</strong>{% if item.description %}<p>{{ item.description }}</p>{% endif %}</div>
          </li>
          {%- endfor %}
        </ol>
        <p class="note">{{ schedule.note }}</p>
      </div>
    </section>

    <!-- ===== Fee ===== -->
    <section id="fee" class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Fee &amp; Items</span>
          <h2 class="section-title">{{ ui.section_fee }}</h2>
        </div>
        <div class="fee-grid">
          <div class="fee-card">
            <h3>{{ ui.fee_title }}</h3>
            <p class="fee-amount">{{ fee.amount }}</p>
            <p>{{ fee.amount_note }}</p>
          </div>
          <div class="fee-card">
            <h3>{{ ui.bring_title }}</h3>
            <ul class="check-list">
              {%- for item in fee.bring_items %}
              <li>{{ item }}</li>
              {%- endfor %}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Register ===== -->
    <section id="register" class="section section-cta">
      <div class="container register-inner">
        <span class="section-label light">Registration</span>
        <h2 class="section-title light">{{ ui.section_register }}</h2>
        <p class="register-lead">{{ register.lead }}</p>
        <div class="register-box">
          <p class="register-contact-name">{{ ui.register_contact }} <strong>{{ register.contact_name }}</strong></p>
          <ul class="register-methods">
            <li><a href="mailto:{{ register.email }}">{{ ui.register_email_prefix }} {{ register.email }}</a></li>
            <li><a href="{{ register.x_url }}" target="_blank" rel="noopener noreferrer">{{ register.x_label }}</a></li>
          </ul>
          <p class="register-required">{{ ui.register_fields }}:</p>
          <ul class="register-fields">
            {%- for field in register.required_fields %}
            <li>{{ field }}</li>
            {%- endfor %}
          </ul>
          <p class="register-note">{{ register.note }}</p>
        </div>
      </div>
    </section>

    <!-- ===== Gallery ===== -->
    <section id="gallery" class="section">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Gallery</span>
          <h2 class="section-title">{{ ui.section_gallery }}</h2>
          <p class="section-desc">{{ gallery.description }}</p>
        </div>
        <div class="gallery-grid">
          {%- for image in gallery.images %}
          <button class="gallery-item" data-full="{{ asset_prefix }}{{ image.src }}"><img src="{{ asset_prefix }}{{ image.src }}" alt="{{ image.alt }}" loading="lazy" /></button>
          {%- endfor %}
        </div>
      </div>
    </section>
  </main>

  <!-- ===== Footer ===== -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="brand-mark">🎾</span>
        <span>{{ site.footer_title }}</span>
      </div>
      <nav class="footer-nav">
        <a href="#about">{{ nav.about }}</a>
        <a href="#access">{{ nav.access }}</a>
        <a href="#schedule">{{ nav.schedule }}</a>
        <a href="#register">{{ nav.register }}</a>
      </nav>
      <p class="copyright">&copy; <span id="year"></span> {{ site.copyright }}</p>
    </div>
  </footer>

  <!-- ===== Lightbox ===== -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="{{ ui.lightbox_close }}">&times;</button>
    <img src="" alt="{{ ui.lightbox_alt }}" id="lightboxImg" />
  </div>

  <script src="{{ asset_prefix }}js/main.js"></script>
</body>
</html>
