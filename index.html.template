<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ site.description }}" />
  <title>{{ site.title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="css/style.css" />
</head>
<body>
  <!-- ===== Header / Nav ===== -->
  <header class="site-header" id="top">
    <div class="container nav-bar">
      <a href="#top" class="brand">
        <span class="brand-mark">🎾</span>
        <span class="brand-text">{{ site.brand }}</span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="メニューを開く" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <nav class="nav-menu" id="navMenu">
        <a href="#about">概要</a>
        <a href="#access">日時・会場</a>
        <a href="#schedule">スケジュール</a>
        <a href="#fee">参加費</a>
        <a href="#gallery">ギャラリー</a>
        <a href="#register" class="nav-cta">参加申込</a>
      </nav>
    </div>
  </header>

  <!-- ===== Hero ===== -->
  <section class="hero{% if hero.background %} hero--image{% endif %}">
    {%- if hero.background %}
    <img class="hero-bg" src="{{ hero.background }}" alt="" aria-hidden="true" />
    <div class="hero-overlay" aria-hidden="true"></div>
    {%- endif %}
    <div class="container hero-content">
      <p class="hero-kicker">{{ hero.kicker }}</p>
      <h1 class="hero-title">{{ hero.title }}</h1>
      <p class="hero-sub">{{ hero.subtitle }}</p>
      <div class="hero-meta">
        {%- for chip in hero.chips %}
        <span class="hero-chip">{{ chip }}</span>
        {%- endfor %}
      </div>
      <div class="hero-actions">
        <a href="#register" class="btn btn-primary">参加を申し込む</a>
        <a href="#about" class="btn btn-ghost">詳しく見る</a>
      </div>
    </div>
  </section>

  <main>
    <!-- ===== About ===== -->
    <section id="about" class="section">
      <div class="container">
        <div class="section-head">
          <span class="section-label">About</span>
          <h2 class="section-title">イベント概要</h2>
        </div>
        <div class="about-grid">
          <div class="about-lead">
            {%- for paragraph in about.paragraphs %}
            <p>{{ paragraph }}</p>
            {%- endfor %}
          </div>
          <ul class="about-points">
            {%- for point in about.points %}
            <li><span class="point-ico">{{ point.icon }}</span><div><strong>{{ point.title }}</strong><p>{{ point.text }}</p></div></li>
            {%- endfor %}
          </ul>
        </div>
        <p class="organizer">主催: {{ about.organizer_main }} ／ 共催・協力: {{ about.organizer_co }}</p>
      </div>
    </section>

    <!-- ===== Date & Venue ===== -->
    <section id="access" class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Date &amp; Venue</span>
          <h2 class="section-title">日時・会場</h2>
        </div>
        <div class="info-cards">
          <div class="info-card">
            <h3>📅 日時</h3>
            <p class="info-big">{{ access.date.headline }}</p>
            <p>{{ access.date.detail }}</p>
          </div>
          <div class="info-card">
            <h3>📍 会場</h3>
            <p class="info-big">{{ access.venue.headline }}</p>
            <p>{{ access.venue.detail }}</p>
          </div>
          <div class="info-card">
            <h3>🚃 アクセス</h3>
            <p class="info-big">{{ access.transport.headline }}</p>
            <p>{{ access.transport.detail }}</p>
          </div>
        </div>
        <div class="map-frame">
          <div class="map-placeholder">
            <span>{{ access.map.message }}</span>
            <a href="{{ access.map.url }}" class="btn btn-ghost btn-sm"{% if access.map.placeholder %} data-placeholder{% endif %}>{{ access.map.label }}</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Schedule ===== -->
    <section id="schedule" class="section">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Schedule</span>
          <h2 class="section-title">当日スケジュール・対戦形式</h2>
        </div>
        <ol class="timeline">
          {%- for item in schedule.timeline %}
          <li>
            <span class="tl-time">{{ item.time }}</span>
            <div class="tl-body"><strong>{{ item.title }}</strong><p>{{ item.description }}</p></div>
          </li>
          {%- endfor %}
        </ol>
        <p class="note">{{ schedule.note }}</p>
      </div>
    </section>

    <!-- ===== Fee ===== -->
    <section id="fee" class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Fee &amp; Items</span>
          <h2 class="section-title">参加費・持ち物</h2>
        </div>
        <div class="fee-grid">
          <div class="fee-card">
            <h3>参加費</h3>
            <p class="fee-amount">{{ fee.amount }}</p>
            <p>{{ fee.amount_note }}</p>
          </div>
          <div class="fee-card">
            <h3>持ち物</h3>
            <ul class="check-list">
              {%- for item in fee.bring_items %}
              <li>{{ item }}</li>
              {%- endfor %}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Register ===== -->
    <section id="register" class="section section-cta">
      <div class="container register-inner">
        <span class="section-label light">Registration</span>
        <h2 class="section-title light">参加申込</h2>
        <p class="register-lead">{{ register.lead }}</p>
        <a href="{{ register.form.url }}" class="btn btn-primary btn-lg"{% if register.form.placeholder %} data-placeholder{% endif %}>{{ register.form.label }}</a>
        <p class="contact">
          お問い合わせ: <a href="mailto:{{ register.contact.email }}"{% if register.contact.placeholder %} data-placeholder{% endif %}>{{ register.contact.label }}</a>
        </p>
      </div>
    </section>

    <!-- ===== Gallery ===== -->
    <section id="gallery" class="section">
      <div class="container">
        <div class="section-head">
          <span class="section-label">Gallery</span>
          <h2 class="section-title">フォトギャラリー</h2>
          <p class="section-desc">{{ gallery.description }}</p>
        </div>
        <div class="gallery-grid">
          {%- for image in gallery.images %}
          <button class="gallery-item" data-full="{{ image.src }}"><img src="{{ image.src }}" alt="{{ image.alt }}" loading="lazy" /></button>
          {%- endfor %}
        </div>
      </div>
    </section>
  </main>

  <!-- ===== Footer ===== -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="brand-mark">🎾</span>
        <span>{{ site.footer_title }}</span>
      </div>
      <nav class="footer-nav">
        <a href="#about">概要</a>
        <a href="#access">日時・会場</a>
        <a href="#schedule">スケジュール</a>
        <a href="#register">参加申込</a>
      </nav>
      <p class="copyright">&copy; <span id="year"></span> {{ site.copyright }}</p>
    </div>
  </footer>

  <!-- ===== Lightbox ===== -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="閉じる">&times;</button>
    <img src="" alt="拡大表示" id="lightboxImg" />
  </div>

  <script src="js/main.js"></script>
</body>
</html>
